# Copy to .env for local development. Never commit real secrets.
PORT=3000
HOST=0.0.0.0

# Where the SQLite db, originals/ and derivatives/ live (mounted as a volume in prod).
DATA_DIR=./data

# Admin ingestion auth (HMAC-signed requests). Generate strong random values.
#   ADMIN_KEY_ID:     a public identifier for the key (sent as X-Key-Id)
#   ADMIN_HMAC_SECRET: the shared secret used to sign requests
ADMIN_KEY_ID=local-dev
ADMIN_HMAC_SECRET=change-me-to-a-long-random-string

# Contact page. Greeting falls back to "Get in Touch" when unset or empty.
CONTACT_EMAIL=hello@example.com
CONTACT_GREETING=Get in Touch

# Ingest pipeline tuning. Defaults are sized for a 2 vCPU / 2 GB container.
#   INGEST_CONCURRENCY: photos decoded/encoded at once across all requests (default 1)
#   SHARP_CONCURRENCY:  libvips threads per sharp op (default: min(2, cpu cores))
# Keep INGEST_CONCURRENCY * SHARP_CONCURRENCY <= core count so ingest never
# starves request serving.
INGEST_CONCURRENCY=1
SHARP_CONCURRENCY=2

# Boot-time knobs — consumed by libuv/V8 before app code, so they must be real
# process env (the app cannot apply them from this file at runtime). Set them on
# the start command (package.json) or the container env, not via dotenv loading.
#   UV_THREADPOOL_SIZE=4
#   NODE_OPTIONS=--max-old-space-size=1024
